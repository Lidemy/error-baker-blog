{
  "name": "eleventy-high-performance-blog",
  "version": "5.0.2",
  "license": "MIT",
  "description": "A starter repository for a blog web site using the Eleventy static site generator.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "clean": "node scripts/clean-output.js",
    "build": "npm run clean && npm run check-tags && npm run js-build && eleventy && npm run test",
    "watch": "concurrently \"eleventy --serve\" \"npm run js-build-watch\"",
    "serve": "eleventy --serve",
    "js-build": "rollup -c rollup.config.js",
    "js-build-watch": "rollup -c rollup.config.js -w",
    "debug": "DEBUG=* eleventy && npm run test",
    "test": "npm run test:site && npm run test:translations && npm run check-tags",
    "test:site": "node scripts/assert-site-built.js && mocha --timeout 10000 test/test*.js",
    "test-watch": "mocha test/test*.js --watch",
    "diff-site": "node scripts/diff-site.js",
    "check-translations": "node scripts/check-translations.js",
    "check-translations:all": "node scripts/check-translations.js --all",
    "check-tags": "node scripts/check-tags.js",
    "test:translations": "node scripts/check-translations.test.js && npm run check-translations:all"
  },
  "pre-push": [
    "build"
  ],
  "pre-commit": [
    "check-translations",
    "check-tags"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/11ty/eleventy-base-blog.git"
  },
  "bugs": {
    "url": "https://github.com/11ty/eleventy-base-blog/issues"
  },
  "homepage": "https://github.com/11ty/eleventy-base-blog#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-navigation": "^1.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@ampproject/toolbox-optimizer": "^2.7.5",
    "any-shell-escape": "^0.1.1",
    "clean-css": "^4.2.3",
    "concurrently": "^5.2.0",
    "csso": "^4.0.3",
    "datauri": "^3.0.0",
    "ffmpeg-static": "^4.2.7",
    "hasha": "^5.2.0",
    "html-minifier": "^4.0.0",
    "image-size": "^0.8.3",
    "jsdom": "^15.1.1",
    "luxon": "^1.21.3",
    "markdown-it": "^8.4.2",
    "markdown-it-anchor": "^5.2.5",
    "mocha": "^8.1.3",
    "pre-commit": "^1.2.2",
    "pre-push": "^0.1.1",
    "purge-from-html": "^1.0.3",
    "purgecss": "^2.3.0",
    "rollup": "^2.23.0",
    "rollup-plugin-terser": "^6.1.0",
    "sharp": "^0.28.3"
  }
}
