{%- set pageLang = lang or 'zh-TW' %}
{%- set t = i18n[pageLang] or i18n['zh-TW'] %}
{%- if translationKey == 'home' %}
  {%- set langVersions = collections.siteLangsWithPublishedPosts | homeVersions %}
{%- elif translationKey == 'about' %}
  {%- set langVersions = collections.siteLangsWithPublishedPosts | aboutVersions %}
{%- elif translationKey %}
  {%- set langVersions = collections.translations[translationKey] %}
{%- else %}
  {%- set langVersions = none %}
{%- endif %}
{%- set homeUrl = '/' if pageLang == 'zh-TW' else '/' + pageLang + '/' %}
<!doctype html>
<html lang="{{ pageLang }}"
    domain="{{ metadata.domain }}"
    {% if googleanalytics %}
    ga-id="{{ googleanalytics }}"
    {% endif %}
  >
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="index, follow">
    <meta name="google-site-verification" content="zbyBgfDuOtaLUTLY7nVzYLdVhNdDIxUCv2xA0R3J1W8" />
    {% if isdevelopment %}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    {% else %}
    <link rel="icon" href="{{ '/img/favicon/favicon-192x192.png' | addHash }}" type="image/png">
    {% endif %}
    <meta name="theme-color" content="#d04444">
    {%- set pageTitle = renderData.title or title or metadata.title %}
    <title>{% if templateClass == 'tmpl-post' and (renderData.title or title) %}{{ pageTitle | escape }}｜{{ t.siteName or metadata.title }}{% else %}{{ pageTitle | escape }}{% endif %}</title>
    <meta property="og:title" content="{{ pageTitle | escape }}">
    <meta name="twitter:title" content="{{ pageTitle | escape }}">
    {% set desc = renderData.description or description %}
    {% if not desc %}
      {% set desc = content | striptags | truncate(140) %}
    {% endif %}
    {% if desc %}
      <meta name="description" content="{{ desc | escape  }}">
      <meta property="og:description" content="{{ desc | escape }}">
      <meta name="twitter:description" content="{{ desc | escape  }}">
    {% endif %}
    <meta name="twitter:card" content="summary">
    {% if metadata.author.twitterHandle !== '' %}
      <meta name="twitter:site" content="@{{ metadata.author.twitterHandle }}">
      <meta name="twitter:creator" content="@{{ metadata.author.twitterHandle }}">
    {% endif %}
    {% if image %}
      <meta property="og:image" content="{{ image | absoluteUrl(metadata.url) }}">
    {% else %}
      <meta property="og:image" content="{{ metadata.ogimage }}">
    {% endif %}
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{ metadata.url }}{{ canonicalUrl or page.url }}">
    <meta property="og:site_name" content="{{ t.siteName or metadata.title }}">
    <meta property="og:locale" content="{{ t.ogLocale }}">
    {%- if langVersions and langVersions.length > 1 %}
      {%- for v in langVersions %}{% if v.lang != pageLang %}
    <meta property="og:locale:alternate" content="{{ i18n[v.lang].ogLocale }}">
      {%- endif %}{% endfor %}
    {%- endif %}

    <link rel="canonical" href="{{ metadata.url }}{{ canonicalUrl or page.url }}">
    {#- hreflang alternates: link every translated version of this article, plus
        x-default pointing at the zh-TW source. #}
    {%- if langVersions and langVersions.length > 1 %}
      {%- for v in langVersions %}
    <link rel="alternate" hreflang="{{ v.lang }}" href="{{ metadata.url }}{{ v.url }}">
        {%- if v.lang == 'zh-TW' %}
    <link rel="alternate" hreflang="x-default" href="{{ metadata.url }}{{ v.url }}">
        {%- endif %}
      {%- endfor %}
    {%- endif %}
    <!-- This is a blog and so it SHOULD be safe and it is nice for the web
         to send referrers cross-origin.
         However, if you use sensitive data in URLs, consider changing this to
         a value like `origin-when-cross-origin`
         https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Referrer-Policy
          -->
    <meta name="referrer" content="always">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">

    <link rel="preconnect" href="/" crossorigin>
    <script async defer src="{{ "/js/min.js" | addHash }}"
      {% if webvitals %}data-cwv-src="{{ "/js/web-vitals.js" | addHash }}"{% endif %}>
    </script>
    {% if googleanalytics %}
      <script async defer src="{{ "/js/cached.js" | addHash }}"></script>
    {% endif %}
    <!-- Notably iOS UAs also contain Mac OS X -->
    <script csp-hash>if (/Mac OS X/.test(navigator.userAgent))document.documentElement.classList.add('apple')
    </script>
    <!-- css is inserted by optimize-html custom plugin -->
  </head>
  <body>
    <script>
      // light/dark theme switch
      const bodyEl = document.querySelector("body");
      const DARK = "dark";
      const LIGHT = "light";
      
      (function initTheme() {
        const currentTheme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? DARK : LIGHT);
        if (currentTheme === DARK) {
          bodyEl.classList.add(DARK);
        }
      })();

      window.addEventListener("DOMContentLoaded", () => {
        const toggleEl = document.querySelector("#color-scheme-toggle");
        toggleEl.addEventListener("click", handleToggleEvent);

        function handleToggleEvent() {
          const isDark = bodyEl.classList.toggle(DARK);
          const theme = isDark ? DARK : LIGHT;
          setTheme(theme);
          localStorage.setItem("theme", theme);
        }

        function setTheme(theme) {
          if (theme === DARK) {
            setUtterancesTheme(DARK);
            toggleEl.src = toggleEl.src.replace(DARK, LIGHT);
          } else {
            setUtterancesTheme(LIGHT);
            toggleEl.src = toggleEl.src.replace(LIGHT, DARK);
          }
        }
      });
    </script>
    <header>
      <nav>
        <div id="nav">
          <h1>
            <a href="{{ homeUrl | url }}" title="Homepage">{{ t.siteName or metadata.title }}</a>
            <label for="menu__control" class="menu__btn">
              <span>{{ t.menu }}</span>
            </label>
          </h1>
          <img id="color-scheme-toggle" src="{{ '/img/dark.svg' | url }}" alt="switch dark mode" />
          {#- Read more about `eleventy-navigation` at https://www.11ty.dev/docs/plugins/navigation/ #}
          <input id="menu__control" type="checkbox" />
          <div class="nav__links">
          {#- zh-TW shows the full chrome (Archive/Tags/About). Other languages
              only have a translated About + Home, so Archive/Tags (zh-TW-only
              browse) are hidden and About points at the per-language page. #}
          {%- for entry in collections.all | eleventyNavigation %}
            {%- if pageLang == 'zh-TW' or entry.key == 'About' %}
            {%- set navHref = ('/' + pageLang + '/about/') if (pageLang != 'zh-TW' and entry.key == 'About') else entry.url %}
            <a class="nav__link" href="{{ navHref | url }}">{{ i18n[pageLang]['nav_' + entry.key] or entry.title }}</a>
            {%- endif %}
          {%- endfor %}
          {#- Language switcher as a compact dropdown (native <details>, no JS).
              Available languages link; missing ones are shown disabled. #}
          <details class="lang-switch">
            <summary class="lang-switch__btn" aria-label="{{ t.readInYourLanguage }}">
              <svg class="lang-switch__globe" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 16 0 18M12 3c-2.5 2.5-2.5 16 0 18"/></svg>
              <span>{{ i18n[pageLang].langName }}</span>
              <svg class="lang-switch__chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <ul class="lang-switch__menu">
            {%- for code in langs %}
              {%- set target = langVersions | urlForLang(code) %}
              {%- if code == pageLang %}
              <li><span class="lang-switch__item is-current" aria-current="true">{{ i18n[code].langName }}</span></li>
              {%- elif target %}
              <li><a class="lang-switch__item" href="{{ target | url }}" hreflang="{{ code }}" lang="{{ code }}">{{ i18n[code].langName }}</a></li>
              {%- else %}
              <li><span class="lang-switch__item is-disabled" aria-disabled="true" title="{{ t.noTranslation }}">{{ i18n[code].langName }}</span></li>
              {%- endif %}
            {%- endfor %}
            </ul>
          </details>
          </div>
        </div>
        <div id="reading-progress" aria-hidden="true"></div>
      </nav>
      <h1 class="w-full">{{ title }}</h1>
      {% block extraArticleHeader %}{% endblock %}
      <dialog id="message"></dialog>
      {% if googleanalytics %}
      <noscript>
        <img src="/.netlify/functions/ga?v=1&_v=j83&t=pageview&dr=https%3A%2F%2Fno-script.com&_s=1&dh={{ metadata.domain | encodeURIComponent }}&dp={{ page.url | encodeURIComponent }}&ul=en-us&de=UTF-8&dt={{title|encodeURIComponent}}&tid={{googleanalytics}}" width="1" height="1"
        style="display:none" alt="">
      </noscript>
      {% endif %}
    </header>

    <main>
      <article>
        {% block article %}
          {{ content | safe }}
        {% endblock %}
      </article>
    </main>

    {#- Locale-suggestion banner: only render when this page has another visible
        language version, then stay hidden unless src/main.js finds a better
        match among the hreflang alternates in <head>. Fixed-position so
        revealing it causes no layout shift. No auto-redirect (SEO-safe). #}
    {%- if langVersions and langVersions.length > 1 %}
    <aside id="lang-suggest" class="lang-suggest" hidden
      data-strings="{{ i18n | langSuggestStrings(langs) }}">
      <span class="lang-suggest__text"></span>
      <a class="lang-suggest__link" href="#"></a>
      <button class="lang-suggest__dismiss" type="button" aria-label="{{ t.suggestDismiss }}">&#10005;</button>
    </aside>
    {%- endif %}

    <footer>
      <div class="copyright">&copy; 2021&ndash;{{ year }} {{ t.copyright }}</div>
      <a href="{{ metadata.feed.id + metadata.feed.path | url }}" id="rss"><img  src="/img/rss-feed.svg" alt="rss feed" /></a>
    </footer>

    <!-- Current page: {{ page.url | url }} -->
    <script>
      var isUtterancesLoaded = false
      window.addEventListener('message', event => {
        if (event.origin !== 'https://utteranc.es') {
          return;
        }
        isUtterancesLoaded = true
      });
      function setUtterancesTheme(theme) {
        let utterancesIframe = document.querySelector('.utterances iframe')
        if (!isUtterancesLoaded) {
          return requestAnimationFrame(() => setUtterancesTheme(theme))
        }
        utterancesIframe.contentWindow.postMessage({
          type: 'set-theme',
          theme: theme === DARK ? 'github-dark-orange' : 'github-light'
        }, 'https://utteranc.es');
      }

    </script>
  </body>
</html>
